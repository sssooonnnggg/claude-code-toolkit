{
  "name": "claudecode-toolkit",
  "displayName": "Toolkit for Claude Code",
  "description": "Handy enhancements for the Claude Code VSCode extension. First feature: pin important sessions to the top of a sidebar list.",
  "version": "0.1.1",
  "publisher": "sssooonnnggg",
  "license": "MIT",
  "icon": "media/icon.png",
  "author": { "name": "sssooonnnggg" },
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "keywords": ["claude", "claude code", "anthropic", "sessions", "pin", "productivity"],
  "repository": { "type": "git", "url": "https://github.com/sssooonnnggg/claude-code-toolkit.git" },
  "bugs": { "url": "https://github.com/sssooonnnggg/claude-code-toolkit/issues" },
  "homepage": "https://github.com/sssooonnnggg/claude-code-toolkit#readme",
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claudeCodeToolkit",
          "title": "Toolkit for Claude Code",
          "icon": "media/pin.svg"
        }
      ]
    },
    "views": {
      "claudeCodeToolkit": [
        { "id": "claudeCodeToolkit.sessions", "name": "Sessions" }
      ]
    },
    "commands": [
      { "command": "claudeCodeToolkit.sessions.refresh", "title": "Refresh Sessions", "category": "Toolkit for Claude Code", "icon": "$(refresh)" },
      { "command": "claudeCodeToolkit.sessions.open", "title": "Open Session", "category": "Toolkit for Claude Code" },
      { "command": "claudeCodeToolkit.sessions.pin", "title": "Pin Session", "category": "Toolkit for Claude Code", "icon": "$(pin)" },
      { "command": "claudeCodeToolkit.sessions.unpin", "title": "Unpin Session", "category": "Toolkit for Claude Code", "icon": "$(pinned)" }
    ],
    "menus": {
      "commandPalette": [
        { "command": "claudeCodeToolkit.sessions.open", "when": "false" },
        { "command": "claudeCodeToolkit.sessions.pin", "when": "false" },
        { "command": "claudeCodeToolkit.sessions.unpin", "when": "false" }
      ],
      "view/title": [
        { "command": "claudeCodeToolkit.sessions.refresh", "when": "view == claudeCodeToolkit.sessions", "group": "navigation" }
      ],
      "view/item/context": [
        { "command": "claudeCodeToolkit.sessions.pin", "when": "view == claudeCodeToolkit.sessions && viewItem == unpinnedSession", "group": "inline" },
        { "command": "claudeCodeToolkit.sessions.unpin", "when": "view == claudeCodeToolkit.sessions && viewItem == pinnedSession", "group": "inline" }
      ]
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "test": "vitest run",
    "vscode:prepublish": "node esbuild.js --production"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.21.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
