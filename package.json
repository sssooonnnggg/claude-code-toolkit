{
  "name": "claude-session-organizer",
  "displayName": "Claude Session Organizer",
  "description": "Organize your Claude Code sessions: pin, group, color, rename, and search them from a sidebar.",
  "version": "0.6.1",
  "publisher": "sssooonnnggg",
  "license": "MIT",
  "icon": "media/icon.png",
  "author": { "name": "sssooonnnggg" },
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "keywords": ["claude", "claude code", "anthropic", "sessions", "pin", "productivity"],
  "repository": { "type": "git", "url": "https://github.com/sssooonnnggg/claude-session-organizer.git" },
  "bugs": { "url": "https://github.com/sssooonnnggg/claude-session-organizer/issues" },
  "homepage": "https://github.com/sssooonnnggg/claude-session-organizer#readme",
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claudeSessionOrganizer",
          "title": "Claude Session Organizer",
          "icon": "media/pin.svg"
        }
      ]
    },
    "views": {
      "claudeSessionOrganizer": [
        { "id": "claudeSessionOrganizer.sessions", "name": "Sessions" }
      ]
    },
    "commands": [
      { "command": "claudeSessionOrganizer.sessions.refresh", "title": "Refresh Sessions", "category": "Claude Session Organizer", "icon": "$(refresh)" },
      { "command": "claudeSessionOrganizer.sessions.open", "title": "Open Session", "category": "Claude Session Organizer" },
      { "command": "claudeSessionOrganizer.sessions.pin", "title": "Pin Session", "category": "Claude Session Organizer", "icon": "$(pin)" },
      { "command": "claudeSessionOrganizer.sessions.unpin", "title": "Unpin Session", "category": "Claude Session Organizer", "icon": "$(pinned)" },
      { "command": "claudeSessionOrganizer.sessions.rename", "title": "Rename Session", "category": "Claude Session Organizer", "icon": "$(edit)" },
      { "command": "claudeSessionOrganizer.sessions.copyId", "title": "Copy Session ID", "category": "Claude Session Organizer" },
      { "command": "claudeSessionOrganizer.sessions.copyPath", "title": "Copy Transcript Path", "category": "Claude Session Organizer" },
      { "command": "claudeSessionOrganizer.sessions.delete", "title": "Delete Session", "category": "Claude Session Organizer", "icon": "$(trash)" },
      { "command": "claudeSessionOrganizer.sessions.search", "title": "Search Sessions", "category": "Claude Session Organizer", "icon": "$(search)" },
      { "command": "claudeSessionOrganizer.sessions.setColor", "title": "Set Color", "category": "Claude Session Organizer", "icon": "$(symbol-color)" },
      { "command": "claudeSessionOrganizer.sessions.setEmoji", "title": "Set Emoji", "category": "Claude Session Organizer", "icon": "$(smiley)" },
      { "command": "claudeSessionOrganizer.sessions.setGroup", "title": "Set Group", "category": "Claude Session Organizer", "icon": "$(folder)" }
    ],
    "menus": {
      "commandPalette": [
        { "command": "claudeSessionOrganizer.sessions.open", "when": "false" },
        { "command": "claudeSessionOrganizer.sessions.pin", "when": "false" },
        { "command": "claudeSessionOrganizer.sessions.unpin", "when": "false" },
        { "command": "claudeSessionOrganizer.sessions.rename", "when": "false" },
        { "command": "claudeSessionOrganizer.sessions.copyId", "when": "false" },
        { "command": "claudeSessionOrganizer.sessions.copyPath", "when": "false" },
        { "command": "claudeSessionOrganizer.sessions.delete", "when": "false" },
        { "command": "claudeSessionOrganizer.sessions.setColor", "when": "false" },
        { "command": "claudeSessionOrganizer.sessions.setEmoji", "when": "false" },
        { "command": "claudeSessionOrganizer.sessions.setGroup", "when": "false" }
      ],
      "view/title": [
        { "command": "claudeSessionOrganizer.sessions.search", "when": "view == claudeSessionOrganizer.sessions", "group": "navigation@1" },
        { "command": "claudeSessionOrganizer.sessions.refresh", "when": "view == claudeSessionOrganizer.sessions", "group": "navigation@2" }
      ],
      "view/item/context": [
        { "command": "claudeSessionOrganizer.sessions.rename", "when": "view == claudeSessionOrganizer.sessions && viewItem =~ /Session$/", "group": "inline@1" },
        { "command": "claudeSessionOrganizer.sessions.pin", "when": "view == claudeSessionOrganizer.sessions && viewItem == unpinnedSession", "group": "inline@2" },
        { "command": "claudeSessionOrganizer.sessions.unpin", "when": "view == claudeSessionOrganizer.sessions && viewItem == pinnedSession", "group": "inline@2" },
        { "command": "claudeSessionOrganizer.sessions.delete", "when": "view == claudeSessionOrganizer.sessions && viewItem =~ /Session$/", "group": "inline@3" },
        { "command": "claudeSessionOrganizer.sessions.setColor", "when": "view == claudeSessionOrganizer.sessions && viewItem =~ /Session$/", "group": "2_customize@1" },
        { "command": "claudeSessionOrganizer.sessions.setEmoji", "when": "view == claudeSessionOrganizer.sessions && viewItem =~ /Session$/", "group": "2_customize@2" },
        { "command": "claudeSessionOrganizer.sessions.setGroup", "when": "view == claudeSessionOrganizer.sessions && viewItem =~ /Session$/", "group": "2_customize@3" },
        { "command": "claudeSessionOrganizer.sessions.copyId", "when": "view == claudeSessionOrganizer.sessions && viewItem =~ /Session$/", "group": "5_copy" },
        { "command": "claudeSessionOrganizer.sessions.copyPath", "when": "view == claudeSessionOrganizer.sessions && viewItem =~ /Session$/", "group": "5_copy" }
      ]
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "test": "vitest run",
    "vscode:prepublish": "node esbuild.js --production"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.21.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
